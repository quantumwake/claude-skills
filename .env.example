# Parent directory for all Claude knowledge (sessions, docs, etc.)
# Session logs go to $KNOWLEDGE_DIR/sessions/<repo>/YYYY-MM-DD.md
# Project docs go to $KNOWLEDGE_DIR/docs/<repo>/README.md
# Example: /home/user/docs
KNOWLEDGE_DIR=

# Root workspace directory containing your projects
# Used by build, test, dep-check, bump-core, find-service, service-map, and docs commands.
# Example: /home/user/Development/myorg
WORKSPACE_DIR=
